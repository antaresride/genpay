{
    "name": "Genpay Rust Dev",
    "build": {
        "dockerfile": "../Dockerfile",
        "context": "..",
        "target": "dev"
    },
    "remoteUser": "root",
    "mounts": [
        "source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.gitignore,target=/root/.gitignore,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,consistency=cached"
    ],
    // Ensure the container has the required Rust components for indexing
    "features": {
        "ghcr.io/devcontainers/features/rust:1": {
            "version": "latest",
            "profile": "minimal"
        }
    },
    "postCreateCommand": "rustup component add rust-analyzer clippy && git config --global core.excludesfile ~/.gitignore && chmod 700 /root/.ssh && chmod 600 /root/.ssh/* || true"
}
